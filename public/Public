function adminAddEmail() {
  const e = document.getElementById('adminEmailInput')?.value.trim().toLowerCase();
  if (!e || !e.includes('@')) return alert('Valid email enter karo (@ hona chahiye)');
  if (premiumEmails.includes(e)) return alert('✅ Yeh email already premium list mein hai!');
  premiumEmails.push(e);
  localStorage.setItem('local_premium_emails', JSON.stringify(premiumEmails));
  if (e === (currentUserEmail || '').toLowerCase()) {
    isPremiumUser = true; DAILY_LIMIT = Infinity; updateUI();
  }
  renderAdminList();
  const input = document.getElementById('adminEmailInput');
  if (input) input.value = '';
  alert('✅ ' + e + ' ko premium add kar diya! ');
}

function adminRemoveEmail() {
  const e = document.getElementById('adminEmailInput')?.value.trim().toLowerCase();
  if (!e) return alert('Pehle email input mein daalo');
  if (!premiumEmails.includes(e)) return alert('⚠️ Yeh email premium list mein nahi hai.');
  adminManualRemove(e);
}

function adminManualRemove(e) {
  if (!confirm('Remove ' + e + ' from premium list?')) return;
  premiumEmails = premiumEmails.filter(em => em !== e);
  localStorage.setItem('local_premium_emails', JSON.stringify(premiumEmails));
  if (e === (currentUserEmail || '').toLowerCase()) {
    isPremiumUser = false; DAILY_LIMIT = 5; loadDailyCount(); updateUI();
  }
  renderAdminList();
  const input = document.getElementById('adminEmailInput');
  if (input) input.value = '';
}

