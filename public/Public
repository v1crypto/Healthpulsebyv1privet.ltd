let mcqState = null;

async function startMCQTest(){
  if (!curSector || !curSubject) { alert(lang==='hi'?'Pehle ek subject choose karein.':'Please pick a subject first.'); return; }
  if (!incrementUsage()) return;
  const s=SECTORS[curSector];
  document.getElementById('mcqTitle').textContent = s.icon+' '+s.label+' — '+curSubject;
  document.getElementById('mcqLogo').style.background = s.grad;
  document.getElementById('mcqBody').innerHTML = `<div class="mcq-card" style="text-align:center"><div style="font-size:36px;margin-bottom:8px">📝</div><div style="font-weight:800;font-size:18px;margin-bottom:6px">${lang==='hi'?'10 MCQ generate ho rahe hain…':'Generating 10 MCQs…'}</div><div style="color:var(--sub);font-size:13px">${xe(curSubject)} · ${lang==='hi'?'thoda intezaar':'a moment'}</div><div class="dots" style="justify-content:center;margin-top:14px"><span class="dot" style="background:${s.color}"></span><span class="dot" style="background:${s.color};animation-delay:.15s"></span><span class="dot" style="background:${s.color};animation-delay:.3s"></span></div></div>`;
  show('pg-mcq');
  try {
    const langInstr = lang==='hi' ? 'Questions Hinglish (Hindi+English medical terms) mein likhein.' : 'Questions in clear English.';
    const prompt = `Generate exactly 10 high-quality MCQs for ${s.label} → ${curSubject}.
${langInstr}
Each MCQ must be syllabus-relevant, exam-style, with 4 options (A,B,C,D), exactly one correct.
Mix difficulty: 4 easy, 4 medium, 2 hard.
Cover different topics within the subject — do NOT repeat the same concept.
Return ONLY valid JSON, no markdown, this exact shape:
{"questions":[{"q":"question text","options":["A text","B text","C text","D text"],"correct":0,"explanation":"why the correct option is right (1-2 lines)"}]}
"correct" is the 0-based index. Provide exactly 10 items.`;
    
    const raw = await generateMCQ(prompt);
    let parsed;
    try { parsed = JSON.parse(raw); }
    catch(e){ const m = raw.match(/\{[\s\S]*\}/); parsed = m ? JSON.parse(m[0]) : null; }
    if (!parsed || !Array.isArray(parsed.questions) || parsed.questions.length < 1) throw new Error('Could not parse MCQs');
    mcqState = { questions: parsed.questions.slice(0,10), idx: 0, score: 0, answers: [] };
    renderMCQ();
  } catch(e){
    document.getElementById('mcqBody').innerHTML = `<div class="mcq-card"><div style="color:#ff7a8a;font-weight:700">⚠️ ${xe(e.message)}</div><button class="mcq-next show" onclick="startMCQTest()">↻ Retry</button></div>`;
    if(!isPremiumUser){dailyCount--;saveDailyCount();updateUI();}
  }
}

function renderMCQ(){
  const body = document.getElementById('mcqBody');
  const total = mcqState.questions.length;
  if (mcqState.idx >= total) { renderMCQResult(); return; }
  const q = mcqState.questions[mcqState.idx];
  const pct = (mcqState.idx / total) * 100;
  const letters = ['A','B','C','D','E'];
  const opts = (q.options||[]).map((o,i)=>`<button class="mcq-opt" data-i="${i}"><span class="letter">${letters[i]}</span><span>${xe(o)}</span></button>`).join('');
  body.innerHTML = `
    <div class="mcq-progress">
      <div class="mcq-prog-bar"><div class="mcq-prog-fill" style="width:${pct}%"></div></div>
      <div class="mcq-prog-txt">${mcqState.idx+1} / ${total}</div>
    </div>
    <div class="mcq-card">
      <div class="mcq-qnum">${lang==='hi'?'Sawaal':'Question'} ${mcqState.idx+1}</div>
      <div class="mcq-q">${xe(q.q)}</div>
      <div class="mcq-opts" id="mcqOpts">${opts}</div>
      <div class="mcq-expl" id="mcqExpl"></div>
      <button class="mcq-next" id="mcqNext" onclick="nextMCQ()">${lang==='hi'?'Agla sawaal →':'Next question →'}</button>
    </div>`;
  body.querySelectorAll('.mcq-opt').forEach(b=>b.onclick = ()=>pickMCQ(parseInt(b.dataset.i)));
}

function pickMCQ(i){
  const q = mcqState.questions[mcqState.idx];
  const correct = Number(q.correct);
  const btns = document.querySelectorAll('#mcqOpts .mcq-opt');
  btns.forEach((b,bi)=>{
    b.disabled = true;
    if (bi === correct) b.classList.add('correct');
    else if (bi === i) b.classList.add('wrong');
  });
  const isRight = i === correct;
  if (isRight) mcqState.score++;
  mcqState.answers.push({ q:q.q, picked:i, correct, right:isRight });
  const ex = document.getElementById('mcqExpl');
  ex.innerHTML = `<b>${isRight ? (lang==='hi'?'✅ Sahi!':'✅ Correct!') : (lang==='hi'?'❌ Galat.':'❌ Wrong.')}</b> ${xe(q.explanation||'')}`;
  ex.classList.add('show');
  document.getElementById('mcqNext').classList.add('show');
  if (mcqState.idx === mcqState.questions.length - 1) {
    document.getElementById('mcqNext').textContent = lang==='hi' ? 'Result dekhein 🎯' : 'See result 🎯';
  }
}

function nextMCQ(){ mcqState.idx++; renderMCQ(); }

function renderMCQResult(){
  const body = document.getElementById('mcqBody');
  const total = mcqState.questions.length;
  const score = mcqState.score;
  const pct = Math.round((score/total)*100);
  let grade, tag;
  if (pct >= 90) { grade='🔥 Outstanding!'; tag=lang==='hi'?'Tu toh topper hai!':"You're a topper!"; }
  else if (pct >= 70) { grade='💪 Great work!'; tag=lang==='hi'?'Bahut badhiya, thoda aur push.':'Solid — keep pushing.'; }
  else if (pct >= 50) { grade='📈 Keep going'; tag=lang==='hi'?'Revision karke wapas aao.':'Revise and retake.'; }
  else { grade='📚 Needs revision'; tag=lang==='hi'?'Concepts dohraen, phir test do.':'Brush up concepts and retry.'; }
  body.innerHTML = `<div class="mcq-result">
    <div class="mcq-score">${score}<small>/${total}</small></div>
    <div class="mcq-grade">${grade}</div>
    <div class="mcq-tag">${xe(tag)} · ${pct}%</div>
    <div class="mcq-acts">
      <button class="primary" onclick="startMCQTest()">↻ ${lang==='hi'?'Naya test':'New test'}</button>
      <button class="secondary" onclick="exitMCQ()">${lang==='hi'?'Chat par wapas':'Back to chat'}</button>
    </div>
  </div>`;
}

