<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
<title>HealthPulse Pro · Veda AI ✨</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style>
  *{margin:0;padding:0;box-sizing:border-box}
  :root{
    --bg:#000000;
    --bg-2:#070709;
    --bg-3:#0d0d12;
    --surface:rgba(255,255,255,0.035);
    --surface-2:rgba(255,255,255,0.06);
    --border:rgba(255,255,255,0.08);
    --border-2:rgba(255,255,255,0.18);
    --text:#f5f5f7;
    --sub:#a8a8b5;
    --muted:#6a6a7a;
    --lime:#c2ff3d;
    --pink:#ff3df0;
    --cyan:#3df0ff;
    --violet:#9d6cff;
    --orange:#ff7a3d;
    --red:#ff3d6e;
    --green:#3dff9d;
    --grad-main:linear-gradient(135deg,#c2ff3d 0%,#3df0ff 50%,#9d6cff 100%);
    --grad-pink:linear-gradient(135deg,#ff3df0,#9d6cff);
    --grad-lime:linear-gradient(135deg,#c2ff3d,#3df0ff);
    --grad-warm:linear-gradient(135deg,#ff7a3d,#ff3df0);
    --shadow-glow:0 10px 40px -10px rgba(157,108,255,.5);
  }
  html,body{background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;font-family:'Outfit',system-ui,sans-serif}
  body{position:relative}
  #bg{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;background:radial-gradient(ellipse at top,#0a0612 0%,#000 60%)}
  #bg::before,#bg::after{content:"";position:absolute;width:480px;height:480px;border-radius:50%;filter:blur(120px);opacity:.35;animation:blob 20s ease-in-out infinite}
  #bg::before{background:radial-gradient(circle,#9d6cff,transparent 65%);top:-140px;left:-120px}
  #bg::after{background:radial-gradient(circle,#ff3df0,transparent 65%);bottom:-180px;right:-140px;animation-delay:-8s}
  #grid{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(rgba(255,255,255,.018) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.018) 1px,transparent 1px);background-size:46px 46px;mask-image:radial-gradient(ellipse at center,#000 30%,transparent 80%)}

  .scr{display:none;position:relative;z-index:1;flex-direction:column}
  .scr.on{display:flex}
  #pg-sector{min-height:100vh;align-items:center;padding:90px 18px 60px;overflow-y:auto}
  #pg-subject{min-height:100vh;overflow-y:auto;padding:80px 18px 60px}
  #pg-chat{height:100vh;overflow:hidden}
  #pg-premium{min-height:100vh;align-items:center;padding:90px 18px 60px;overflow-y:auto}
  #pg-mcq{height:100vh;overflow:hidden;display:none;flex-direction:column}
  #pg-mcq.on{display:flex}
  #pg-payment{height:100vh;overflow:hidden;display:none;flex-direction:column}
  #pg-payment.on{display:flex}

  .topbar{position:fixed;top:12px;left:12px;right:12px;z-index:200;background:rgba(10,8,16,.88);backdrop-filter:blur(24px) saturate(160%);-webkit-backdrop-filter:blur(24px) saturate(160%);border:1px solid rgba(157,108,255,.18);border-radius:22px;padding:8px 10px 8px 14px;display:flex;align-items:center;justify-content:space-between;gap:10px;box-shadow:0 8px 32px rgba(0,0,0,.7),0 0 0 1px rgba(255,255,255,.03)}
  .tb-left{display:flex;align-items:center;gap:10px;min-width:0;flex:1;overflow:hidden}
  .tb-right{display:flex;align-items:center;gap:6px;flex-shrink:0}
  .tb-icon-btn{background:var(--surface);border:1px solid var(--border);color:var(--sub);border-radius:12px;width:34px;height:34px;font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0}
  .tb-icon-btn:hover{border-color:rgba(157,108,255,.5);color:var(--violet);background:rgba(157,108,255,.1)}
  .tb-logo{width:34px;height:34px;border-radius:12px;background:var(--grad-main);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#000;font-family:'Outfit';box-shadow:0 0 20px rgba(194,255,61,.4);cursor:pointer}
  .tb-name{color:var(--text);font-size:13px;font-weight:700;letter-spacing:.04em;font-family:'Outfit';white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .tb-name span{background:var(--grad-main);-webkit-background-clip:text;background-clip:text;color:transparent}
  .lang-wrap{display:flex;background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:14px;padding:3px;gap:2px}
  .lb{background:none;border:none;color:var(--sub);font-size:12px;padding:5px 11px;border-radius:11px;cursor:pointer;font-family:'JetBrains Mono';font-weight:700;transition:all .2s}
  .lb.on{background:var(--grad-main);color:#000;box-shadow:0 4px 12px rgba(194,255,61,.3)}
  .premium-badge{background:var(--grad-warm);border:none;color:#fff;padding:7px 12px;border-radius:14px;font-size:11px;font-weight:800;font-family:'Outfit';cursor:pointer;letter-spacing:.04em;box-shadow:0 6px 18px rgba(255,61,240,.35);transition:transform .15s}
  .premium-badge:active{transform:scale(.94)}
  .hero-wrap{display:flex;flex-direction:column;align-items:center;width:100%;max-width:760px}
  .logo-stage{position:relative;width:120px;height:120px;margin-top:14px;display:flex;align-items:center;justify-content:center}
  .logo-anim{width:88px;height:88px;border-radius:28px;background:var(--grad-main);display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:900;color:#000;font-family:'Outfit';box-shadow:0 0 50px rgba(194,255,61,.5),0 0 90px rgba(157,108,255,.35);animation:afloat 5s ease-in-out infinite;cursor:pointer;z-index:2;transform:rotate(-6deg)}
  .logo-ring{position:absolute;inset:0;border-radius:36px;border:1.5px dashed rgba(194,255,61,.4);animation:aspin 14s linear infinite}
  .logo-ring2{position:absolute;inset:-14px;border-radius:42px;border:1px solid rgba(157,108,255,.25);animation:aspin 22s linear infinite reverse}
  .hero-t{font-size:clamp(34px,8vw,54px);font-weight:800;text-align:center;margin:22px 0 8px;letter-spacing:-.03em;line-height:1.02;font-family:'Outfit'}
  .hero-t .accent{background:var(--grad-main);-webkit-background-clip:text;background-clip:text;color:transparent;font-style:italic}
  .vbadge{display:inline-flex;align-items:center;gap:6px;background:rgba(194,255,61,.08);border:1px solid rgba(194,255,61,.3);color:var(--lime);border-radius:99px;padding:6px 14px;font-size:11px;font-family:'JetBrains Mono';font-weight:700;letter-spacing:.12em;text-transform:uppercase}
  .hero-s{color:var(--sub);font-size:15px;text-align:center;max-width:460px;line-height:1.55;margin:14px 0 24px;font-weight:400}
  .hero-s b{color:var(--text);font-weight:600}
  .feat-row{display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-bottom:24px}
  .feat-chip{background:var(--surface);border:1px solid var(--border);color:var(--sub);font-size:11px;padding:6px 12px;border-radius:99px;font-family:'JetBrains Mono';font-weight:600}
  .sgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:14px;width:100%;max-width:760px}
  .scard{position:relative;background:var(--surface);border:1px solid var(--border);border-radius:24px;padding:18px 16px 16px;cursor:pointer;text-align:left;overflow:hidden;transition:transform .25s cubic-bezier(.2,.9,.3,1.1),border-color .2s;backdrop-filter:blur(6px)}
  .scard::before{content:"";position:absolute;inset:0;border-radius:24px;padding:1px;background:linear-gradient(135deg,transparent 40%,var(--c-acc,#fff) 100%);-webkit-mask:linear-gradient(#000,#000) content-box,linear-gradient(#000,#000);-webkit-mask-composite:xor;mask-composite:exclude;opacity:0;transition:opacity .25s;pointer-events:none}
  .scard:hover{transform:translateY(-4px) rotate(-.4deg)}
  .scard:hover::before{opacity:.6}
  .scard:active{transform:translateY(-1px) scale(.99)}
  .sc-emoji{width:46px;height:46px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:12px;background:rgba(255,255,255,.04);border:1px solid var(--border)}
  .sc-label{font-size:15px;font-weight:700;margin-bottom:3px;letter-spacing:-.01em}
  .sc-desc{font-size:11px;color:var(--muted);font-family:'JetBrains Mono';margin-bottom:10px;line-height:1.4}
  .sc-meta{display:flex;align-items:center;justify-content:space-between;font-size:11px;color:var(--sub);font-family:'JetBrains Mono'}
  .sc-arrow{width:24px;height:24px;border-radius:50%;background:var(--c-acc,#fff);color:#000;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:12px}
  .upgrade-note{margin-top:34px;max-width:760px;width:100%;background:linear-gradient(135deg,rgba(255,122,61,.08),rgba(255,61,240,.08));border:1px solid rgba(255,122,61,.22);border-radius:18px;padding:14px 18px;font-size:13px;color:var(--sub);text-align:center;line-height:1.55}
  .upgrade-note b{color:var(--text)}
  .sub-wrap{max-width:760px;width:100%;margin:0 auto}
  .bb{display:inline-flex;align-items:center;gap:6px;background:var(--surface);border:1px solid var(--border);color:var(--sub);border-radius:99px;padding:8px 16px;font-size:13px;font-family:'Outfit';font-weight:600;cursor:pointer;margin-bottom:16px;transition:all .2s}
  .bb:hover{border-color:var(--border-2);color:var(--text)}
  .sbadge{display:flex;align-items:center;gap:14px;background:var(--surface);border:1px solid var(--border);border-radius:22px;padding:16px 18px;margin-bottom:18px;backdrop-filter:blur(8px)}
  .sbadge-icon{width:54px;height:54px;border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:26px;flex-shrink:0;box-shadow:0 8px 24px rgba(0,0,0,.5)}
  .sb-title{font-size:19px;font-weight:800;letter-spacing:-.01em}
  .sb-sub{font-size:12px;color:var(--muted);font-family:'JetBrains Mono';margin-top:2px}
  .pick-row{display:flex;align-items:center;gap:10px;margin-bottom:14px}
  .pick-dot{width:6px;height:6px;border-radius:50%;background:var(--lime);box-shadow:0 0 10px var(--lime)}
  .pick-title{font-size:13px;color:var(--sub);font-family:'JetBrains Mono';font-weight:600;letter-spacing:.08em;text-transform:uppercase}
  .jgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px}
  .jchip{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:14px 16px;color:var(--text);font-size:14px;cursor:pointer;text-align:left;transition:all .2s;font-family:'Outfit';font-weight:500;display:flex;align-items:center;gap:10px}
  .jchip:hover{border-color:var(--border-2);background:var(--surface-2);transform:translateY(-1px)}
  .jchip:active{transform:translateY(0) scale(.99)}
  .jchip-bullet{width:8px;height:8px;border-radius:50%;flex-shrink:0;box-shadow:0 0 10px currentColor}
  #pg-chat{background:linear-gradient(180deg,#070410 0%,#040208 60%,#020105 100%)}
  .chat-hdr{background:rgba(12,6,22,.94);backdrop-filter:blur(28px) saturate(180%);border-bottom:1px solid rgba(157,108,255,.2);padding:10px 14px;display:flex;align-items:center;gap:10px;flex-shrink:0;margin-top:60px;box-shadow:0 1px 24px rgba(157,108,255,.1)}
  .chat-logo{width:38px;height:38px;border-radius:12px;display:flex;align-items:center;justify-content:center;color:#000;font-weight:800;font-size:13px;font-family:'Outfit';flex-shrink:0;box-shadow:0 0 18px rgba(157,108,255,.4)}
  .chat-info{flex:1;min-width:0}
  .chat-brand{color:rgba(157,108,255,.7);font-size:9px;letter-spacing:.14em;font-family:'JetBrains Mono';text-transform:uppercase;font-weight:700}
  .chat-title{font-size:14px;font-weight:700;letter-spacing:-.01em;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .hbtn{background:rgba(157,108,255,.08);border:1px solid rgba(157,108,255,.2);color:var(--sub);border-radius:12px;padding:7px 11px;font-size:12px;font-family:'Outfit';font-weight:600;cursor:pointer;transition:all .15s}
  .hbtn:hover{color:var(--text);border-color:rgba(157,108,255,.5);background:rgba(157,108,255,.15)}
  .hbtn.mcq{background:var(--grad-lime);color:#000;border:none;font-weight:800;box-shadow:0 4px 16px rgba(194,255,61,.25)}
  #ca{flex:1;overflow-y:auto;padding:18px 16px;display:flex;flex-direction:column;gap:14px;max-width:800px;width:100%;margin:0 auto}
  .wlc{text-align:center;padding:24px 8px}
  .wlc-emoji{font-size:48px;margin-bottom:10px;display:inline-block;animation:afloat 4s ease-in-out infinite}
  .wlc-title{font-size:22px;font-weight:800;margin-bottom:6px;letter-spacing:-.02em}
  .wlc-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(194,255,61,.08);border:1px solid rgba(194,255,61,.3);color:var(--lime);font-size:11px;padding:5px 12px;border-radius:99px;font-family:'JetBrains Mono';font-weight:700;letter-spacing:.1em;margin-bottom:18px}
  .wlc-actions{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:18px}
  .wlc-act{background:var(--grad-lime);color:#000;border:none;padding:10px 18px;border-radius:99px;font-size:13px;font-weight:800;cursor:pointer;font-family:'Outfit'}
  .wlc-act.alt{background:var(--grad-warm);color:#fff}
  .wlc-act.pdf{background:var(--surface-2);color:var(--text);border:1px solid var(--border-2)}
  .wlc-act.pay{background:var(--grad-warm);color:#000;border:1px solid var(--lime)}
  .slist{display:flex;flex-direction:column;gap:8px;max-width:440px;margin:0 auto}
  .sqb{background:var(--surface);border:1px solid;border-radius:14px;padding:12px 16px;font-size:14px;cursor:pointer;color:var(--text);text-align:left;font-family:'Outfit';font-weight:500;transition:all .2s;display:flex;align-items:center;gap:10px}
  .sqb::before{content:"✨";font-size:13px}
  .sqb:hover{background:var(--surface-2);transform:translateX(4px)}
  .mrow{display:flex;gap:10px;align-items:flex-start;animation:slideIn .3s ease-out}
  .mrow.u{justify-content:flex-end}
  .avc{width:34px;height:34px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:14px;color:#fff;font-weight:800;font-family:'Outfit';flex-shrink:0;margin-top:2px;box-shadow:0 4px 16px rgba(157,108,255,.5)}
  .ubub{color:#fff;border-radius:20px 6px 20px 20px;padding:11px 16px;font-size:15px;max-width:78%;line-height:1.55;font-weight:600;box-shadow:0 6px 20px rgba(0,0,0,.4)}
  .abub{background:linear-gradient(145deg,rgba(22,10,42,.97),rgba(14,6,28,.95));border:1px solid rgba(157,108,255,.28);border-radius:8px 22px 22px 22px;padding:14px 18px;font-size:15px;max-width:84%;line-height:1.75;backdrop-filter:blur(12px);box-shadow:0 6px 32px rgba(157,108,255,.12),0 0 0 1px rgba(255,255,255,.03)}
  .abub .h3{font-size:12px;font-family:'JetBrains Mono';margin:12px 0 4px;font-weight:700;letter-spacing:.06em;text-transform:uppercase}
  .abub .h3:first-child{margin-top:0}
  .abub .li{padding-left:14px;margin-bottom:4px;color:rgba(200,190,220,.85);position:relative}
  .abub .li::before{content:"→";position:absolute;left:0;color:var(--violet)}
  .abub .pp{margin-bottom:4px;color:rgba(200,190,220,.85)}
  .abub strong{color:#e8d8ff;font-weight:700}
  .file-chip{display:inline-flex;align-items:center;gap:6px;background:rgba(61,240,255,.1);border:1px solid rgba(61,240,255,.3);color:var(--cyan);font-size:11px;padding:4px 10px;border-radius:99px;font-family:'JetBrains Mono';font-weight:600;margin-bottom:6px}
  .dots{display:flex;gap:6px;padding:6px 0;align-items:center}
  .dot{width:8px;height:8px;border-radius:50%;animation:abnc 1.2s infinite}
  .ibar{background:rgba(10,4,20,.96);backdrop-filter:blur(28px);border-top:1px solid rgba(157,108,255,.2);padding:12px 14px 16px;flex-shrink:0;box-shadow:0 -4px 32px rgba(157,108,255,.06)}
  .iinner{max-width:800px;margin:0 auto}
  .attach-bar{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px;min-height:0}
  .attach-bar:empty{display:none}
  .attach-pill{display:inline-flex;align-items:center;gap:6px;background:rgba(61,240,255,.12);border:1px solid rgba(61,240,255,.3);color:var(--cyan);font-size:12px;padding:5px 10px;border-radius:99px;font-family:'JetBrains Mono';font-weight:600}
  .attach-pill .x{cursor:pointer;color:var(--text);font-weight:700;font-size:14px;line-height:1}
  .irow{display:flex;gap:6px;align-items:flex-end;background:rgba(22,10,42,.85);border:1px solid rgba(157,108,255,.22);border-radius:20px;padding:6px 6px 6px 10px;transition:border-color .2s,box-shadow .2s}
  .irow:focus-within{border-color:rgba(157,108,255,.55);box-shadow:0 0 0 4px rgba(157,108,255,.1)}
  .iconbtn{width:38px;height:38px;border:none;border-radius:12px;background:rgba(157,108,255,.1);color:var(--sub);font-size:16px;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .15s}
  .iconbtn:hover{background:rgba(157,108,255,.2);color:var(--text)}
  .iconbtn.rec{background:var(--red);color:#fff;animation:pulse 1.2s infinite}
  #ci{flex:1;background:transparent;border:none;color:var(--text);font-size:15px;font-family:'Outfit';padding:10px 4px;resize:none;outline:none;height:46px;font-weight:500;min-width:0}
  #ci::placeholder{color:rgba(157,108,255,.4)}
  #sb{width:42px;height:42px;border:none;border-radius:14px;color:#fff;font-size:18px;cursor:pointer;font-weight:800;transition:transform .15s;flex-shrink:0;display:flex;align-items:center;justify-content:center}
  #sb:not(:disabled):active{transform:scale(.92)}
  #sb:disabled{opacity:.3;cursor:not-allowed}
  .usage-row{display:flex;justify-content:space-between;font-size:11px;font-family:'JetBrains Mono';font-weight:600;color:var(--muted);margin-top:10px}
  .free-limit-bar{background:rgba(255,255,255,.06);border-radius:99px;height:5px;margin:6px 0;overflow:hidden}
  .free-limit-fill{background:var(--grad-main);height:100%;border-radius:99px;transition:width .4s}
  #upgradeMsg{font-size:11px;color:var(--orange);text-align:center;margin-top:6px;font-family:'Outfit'}
  #upgradeMsg a{color:var(--lime);text-decoration:none;font-weight:600}
  .watch-ad-btn{background:var(--grad-warm);border:none;color:#fff;padding:5px 11px;border-radius:99px;font-size:11px;cursor:pointer;font-weight:700;margin:0 4px}
  .cooldown-timer{color:var(--cyan);font-weight:700;font-size:12px}
  .logout-link{font-size:11px;color:var(--muted);text-align:center;margin-top:8px;cursor:pointer;font-family:'JetBrains Mono'}
  .logout-link:hover{color:var(--text)}
  .mcq-hdr{background:rgba(8,8,12,.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:12px 16px;display:flex;align-items:center;gap:10px;flex-shrink:0;margin-top:60px}
  .mcq-body{flex:1;overflow-y:auto;padding:20px 16px;max-width:760px;width:100%;margin:0 auto}
  .mcq-progress{display:flex;align-items:center;gap:10px;margin-bottom:14px}
  .mcq-prog-bar{flex:1;height:6px;background:rgba(255,255,255,.06);border-radius:99px;overflow:hidden}
  .mcq-prog-fill{height:100%;background:var(--grad-main);border-radius:99px;transition:width .4s}
  .mcq-prog-txt{font-size:12px;font-family:'JetBrains Mono';color:var(--sub);font-weight:700}
  .mcq-card{background:var(--surface);border:1px solid var(--border);border-radius:22px;padding:22px 20px;backdrop-filter:blur(8px)}
  .mcq-qnum{font-size:11px;font-family:'JetBrains Mono';color:var(--lime);letter-spacing:.12em;text-transform:uppercase;font-weight:700;margin-bottom:8px}
  .mcq-q{font-size:18px;font-weight:700;line-height:1.45;letter-spacing:-.01em;margin-bottom:18px}
  .mcq-opts{display:flex;flex-direction:column;gap:10px}
  .mcq-opt{background:var(--bg-3);border:1.5px solid var(--border);border-radius:14px;padding:14px 16px;color:var(--text);text-align:left;cursor:pointer;font-family:'Outfit';font-size:14px;font-weight:500;transition:all .15s;display:flex;align-items:center;gap:12px;line-height:1.4}
  .mcq-opt:hover:not(:disabled){border-color:var(--border-2);background:var(--surface-2)}
  .mcq-opt:disabled{cursor:default}
  .mcq-opt .letter{width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,.06);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;flex-shrink:0;color:var(--sub);font-family:'JetBrains Mono'}
  .mcq-opt.correct{border-color:var(--green);background:rgba(61,255,157,.08);color:var(--text)}
  .mcq-opt.correct .letter{background:var(--green);color:#000}
  .mcq-opt.wrong{border-color:var(--red);background:rgba(255,61,110,.08)}
  .mcq-opt.wrong .letter{background:var(--red);color:#fff}
