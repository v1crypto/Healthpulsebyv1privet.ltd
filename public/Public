    if (email && email.includes('@')) {
      currentUserEmail = email;
      localStorage.setItem('userEmail', email);
      fetchPremiumList().then(() => location.reload());
    } else { 
      if (email !== null) alert("A valid email is required."); 
    }
    return false;
  }
  return true;
