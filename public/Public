function saveQA(question, answer) {
  try {
    let history = JSON.parse(localStorage.getItem('medical_qa_history')) || [];
    const entry = {
      timestamp: new Date().toISOString(),
      sector: curSector || 'unknown',
      subject: curSubject || 'unknown',
      question: question,
      answer: answer
    };
    history.push(entry);
    localStorage.setItem('medical_qa_history', JSON.stringify(history));
  } catch(e) { console.warn('Save QA error:', e); }
}

function downloadData() {
  const data = localStorage.getItem('medical_qa_history');
  if (!data || data === '[]') {
    alert(lang === 'hi' ? 'अभी कोई डेटा नहीं है।' : 'No data yet.');
    return;
  }
  if (!confirm(lang === 'hi' ? 'सारा डेटा JSON फाइल में डाउनलोड करें?' : 'Download all data as JSON?')) return;
  try {
    const blob = new Blob([data], {type: 'application/json'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `HealthPulse_Data_${new Date().toISOString().slice(0,10)}.json`;
    a.click();
    URL.revokeObjectURL(url);
  } catch(e) {
    alert(lang === 'hi' ? 'डाउनलोड में त्रुटि: ' + e.message : 'Download error: ' + e.message);
  }
}

