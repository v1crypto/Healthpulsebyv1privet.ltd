let recognition=null, isRecording=false;

function toggleVoice(){
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { alert('Voice input not supported in this browser. Try Chrome.'); return; }
  if (isRecording) { recognition && recognition.stop(); return; }
  recognition = new SR();
  recognition.lang = lang === 'hi' ? 'hi-IN' : 'en-US';
  recognition.interimResults = true;
  recognition.continuous = false;
  const ci = document.getElementById('ci');
  const startText = ci.value;
  recognition.onstart = ()=>{ isRecording=true; document.getElementById('micBtn').classList.add('rec'); };
  recognition.onend = ()=>{ isRecording=false; document.getElementById('micBtn').classList.remove('rec'); };
  recognition.onerror = (ev)=>{ isRecording=false; document.getElementById('micBtn').classList.remove('rec'); console.warn('voice',ev); };
  recognition.onresult = (ev)=>{
    let txt='';
    for (let i=0;i<ev.results.length;i++) txt += ev.results[i][0].transcript;
    ci.value = (startText ? startText+' ' : '') + txt;
    updBtn();
  };
  recognition.start();
}

