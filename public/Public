async function sendMsg(txt){
  var ci=document.getElementById('ci');
  var msg=(txt!==undefined?txt:ci.value).trim();
  if((!msg && !pendingPDF) || isBusy) return;
  if(!incrementUsage()) return;
  ci.value=''; updBtn();
  var ca=document.getElementById('ca');
  var wlc=ca.querySelector('.wlc'); if(wlc) wlc.remove();
  const userMsg = { role:'user', content: msg || (lang==='hi'?'Is PDF par focus karo':'Use the attached PDF') };
  if (pendingPDF) {
    userMsg.pdf = { mime: pendingPDF.mime, data: pendingPDF.data, name: pendingPDF.name };
  }
  chatHist.push(userMsg);
  addBubble('user', msg, pendingPDF ? pendingPDF.name : null);
  const sentPDF = pendingPDF; pendingPDF=null; renderAttachBar();
  isBusy=true;
  var lid=addLoader();
  try{
    var reply = await callDeepSeek(getSystemMessage(), chatHist);
    rmNode(lid);
    addBubble('ai',reply);
    chatHist.push({role:'assistant',content:reply});
    saveQA(msg || '(PDF attached)', reply);
  }catch(e){
    console.error(e);
    rmNode(lid);
    var em=lang==='hi'?'⚠️ त्रुटि: '+e.message+'\n\nकृपया पुनः प्रयास करें।':'⚠️ Error: '+e.message+'\n\nPlease try again.';
    addBubble('err',em);
    if(chatHist.length>0 && chatHist[chatHist.length-1].role==='user') chatHist.pop();
    if(!isPremiumUser){dailyCount--;saveDailyCount();updateUI();}
  }
  isBusy=false; updBtn();
}

function addBubble(type,text,fileName){
  var ca=document.getElementById('ca');
  var s=SECTORS[curSector];
  var d=document.createElement('div');
  if(type==='user'){
    d.className='mrow u';
    const chip = fileName ? `<div class="file-chip">📄 ${xe(fileName)}</div>` : '';
    d.innerHTML='<div><div style="text-align:right">'+chip+'</div><div class="ubub" style="background:'+s.grad+'">'+xe(text||'(PDF attached)')+'</div></div>';
  }else if(type==='err'){
    d.className='mrow';
    d.innerHTML='<div class="avc" style="background:'+s.grad+'">V</div><div class="abub"><div style="color:#ff7a8a">'+xe(text)+'</div></div>';
  }else{
    d.className='mrow';
    d.innerHTML='<div class="avc" style="background:'+s.grad+'">V</div><div class="abub">'+fmtAI(text,s.color)+'</div>';
  }
  ca.appendChild(d);
  ca.scrollTop=ca.scrollHeight;
}

function addLoader(){
  var ca=document.getElementById('ca');
  var s=SECTORS[curSector];
  var id='ld'+Date.now();
  var d=document.createElement('div');
  d.className='mrow'; d.id=id;
  d.innerHTML='<div class="avc" style="background:'+s.grad+'">V</div><div class="abub"><div class="dots"><span class="dot" style="background:'+s.color+';animation-delay:0s"></span><span class="dot" style="background:'+s.color+';animation-delay:.15s"></span><span class="dot" style="background:'+s.color+';animation-delay:.3s"></span></div></div>';
  ca.appendChild(d);
  ca.scrollTop=ca.scrollHeight;
  return id;
}

function rmNode(id){var e=document.getElementById(id); if(e) e.remove();}

function fmtAI(t,c){
  return t.split('\n').map(l=>{
    if(/^\*\*[^*]+\*\*/.test(l)) return '<div class="h3" style="color:'+c+'">'+inl(l,c)+'</div>';
    if(/^[-•] /.test(l)) return '<div class="li">'+inl(l.slice(2),c)+'</div>';
    if(/^\d+\.\s/.test(l)) return '<div class="li">'+inl(l,c)+'</div>';
    if(l.trim()==='') return '<div style="height:6px"></div>';
    return '<div class="pp">'+inl(l,c)+'</div>';
  }).join('');
}

function inl(t,c){ return xe(t).replace(/\*\*(.*?)\*\*/g,'<strong style="color:'+c+'">$1</strong>'); }

function xe(s){ return String(s).replace(/[&<>]/g,function(m){ return m==='&'?'&amp;':m==='<'?'&lt;':'>'; }); }

function updBtn(){ document.getElementById('sb').disabled=(!document.getElementById('ci').value.trim() && !pendingPDF) || isBusy; }

