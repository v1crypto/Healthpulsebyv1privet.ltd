function logoutUser() { 
  localStorage.removeItem('userEmail'); 
  localStorage.removeItem('hp_daily_count_' + currentUserEmail);
  localStorage.removeItem('hp_count_date_' + currentUserEmail);
  localStorage.removeItem('cooldown_end_' + currentUserEmail);
  location.reload(); 
}

async function fetchPremiumList() {
  const localList = JSON.parse(localStorage.getItem('local_premium_emails') || '[]');
  try {
    const PREMIUM_JSON_URL = "https://raw.githubusercontent.com/YOUR_USERNAME/YOUR_REPO/main/premium-users.json";
    const r = await fetch(PREMIUM_JSON_URL); 
    if (!r.ok) throw new Error();
    const d = await r.json();
    const remoteList = d.premiumEmails || [];
    premiumEmails = [...new Set([...remoteList, ...localList])];
    if (currentUserEmail) isPremiumUser = premiumEmails.includes(currentUserEmail.toLowerCase());
    DAILY_LIMIT = isPremiumUser ? Infinity : 5;
    loadDailyCount();
    checkCooldown();
    updateUI();
    updatePremiumBadge();
    checkPremiumExpiry();
  } catch(e) {
    premiumEmails = localList;
    isPremiumUser = premiumEmails.includes((currentUserEmail||'').toLowerCase());
    DAILY_LIMIT = isPremiumUser ? Infinity : 5;
    loadDailyCount();
    checkCooldown();
    updateUI();
    updatePremiumBadge();
    checkPremiumExpiry();
  }
}

async function checkPremiumExpiry() {
  const email = localStorage.getItem('userEmail');
  if (!email) return;
  
  try {
    const response = await fetch(`${BACKEND_URL}/api/premium-status?email=${encodeURIComponent(email)}`);
    const data = await response.json();
    
    if (data.success && data.isPremium) {
      const statusEl = document.getElementById('premiumStatus');
      if (statusEl) {
        statusEl.innerHTML = `👑 Premium active · ${data.daysLeft} days remaining · Expires on ${new Date(data.expiry).toLocaleDateString()}`;
      }
    } else if (data.success && !data.isPremium) {
      const statusEl = document.getElementById('premiumStatus');
      if (statusEl) {
        statusEl.innerHTML = '⏰ Premium expired or not active. Upgrade now!';
      }
    }
  } catch (error) {
    console.error('Error checking premium expiry:', error);
  }
}

