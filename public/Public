}

function loadDailyCount() {
  if (isPremiumUser) return;
  const saved = localStorage.getItem('hp_daily_count_' + currentUserEmail);
  const date = localStorage.getItem('hp_count_date_' + currentUserEmail);
  const today = new Date().toDateString();
  if (date === today && saved !== null) {
    dailyCount = parseInt(saved);
  } else {
    dailyCount = 0;
    localStorage.setItem('hp_daily_count_' + currentUserEmail, '0');
    localStorage.setItem('hp_count_date_' + currentUserEmail, today);
    adWatchCount = 0;
    localStorage.setItem('hp_ad_watch_count_' + currentUserEmail, '0');
  }
  const adSaved = localStorage.getItem('hp_ad_watch_count_' + currentUserEmail);
  adWatchCount = adSaved ? parseInt(adSaved) : 0;
}

function saveDailyCount() { 
  if (!isPremiumUser && currentUserEmail) {
    localStorage.setItem('hp_daily_count_' + currentUserEmail, dailyCount);
    localStorage.setItem('hp_ad_watch_count_' + currentUserEmail, adWatchCount);
  }
}

function checkCooldown() {
  if (isPremiumUser) return;
  const saved = localStorage.getItem('cooldown_end_' + currentUserEmail);
  if (saved) {
    cooldownEndTime = new Date(parseInt(saved));
    if (cooldownEndTime > new Date()) {
      return;
    } else {
      cooldownEndTime = null;
      localStorage.removeItem('cooldown_end_' + currentUserEmail);
      dailyCount = 0;
      saveDailyCount();
      updateUI();
    }
  }
}

function incrementUsage() {
  if (isPremiumUser) return true;
  
  if (cooldownEndTime && cooldownEndTime > new Date()) {
    const remaining = Math.ceil((cooldownEndTime - new Date()) / (1000 * 60 * 60));
    alert(lang === 'hi' ? `⏳ ${remaining} घंटे बाद फिर से पूछ सकते हैं।` : `⏳ Wait ${remaining} hours before asking again.`);
    return false;
  }
  
  if (dailyCount >= DAILY_LIMIT) {
    if (adWatchCount === 0) {
      showAdModal('single');
    } else if (adWatchCount === 1) {
      showAdModal('double');
    } else {
      startCooldown();
      return false;
    }
    return false;
  }
  dailyCount++;
  saveDailyCount();
  updateUI();
  return true;
}

function startCooldown() {
  const cooldownHours = 12;
  cooldownEndTime = new Date(Date.now() + cooldownHours * 60 * 60 * 1000);
  localStorage.setItem('cooldown_end_' + currentUserEmail, cooldownEndTime.getTime().toString());
  dailyCount = DAILY_LIMIT;
  saveDailyCount();
  updateUI();
  alert(lang === 'hi' ? `⏳ ${cooldownHours} घंटे का cooldown शुरू हो गया है।` : `⏳ ${cooldownHours} hour cooldown started.`);
}

let adMode = 'single';
let adCount = 0;

function showAdModal(mode) {
  adMode = mode || 'single';
  adCount = 0;
  const modal = document.getElementById('adModal');
  modal.classList.add('active');
  
  const title = document.querySelector('#adModal .ad-title');
  const btn = document.getElementById('watchAdBtn');
  const countdown = document.getElementById('adCountdown');
  
  if (mode === 'double') {
    title.innerHTML = 'Watch <span style="color:var(--lime)">2 ads</span> → unlock +5 questions';
    btn.textContent = '▶ Watch Ad 1/2 (30s)';
    adCount = 0;
  } else {
    title.innerHTML = 'Watch ad → unlock <span style="color:var(--lime)">+5 questions</span>';
    btn.textContent = '▶ Watch Ad (30s)';
    adCount = 0;
  }
  
  let t = 30;
  countdown.textContent = t;
  btn.disabled = true;
  if (countdownInterval) clearInterval(countdownInterval);
  countdownInterval = setInterval(() => {
    t--;
    countdown.textContent = t;
    if (t <= 0) {
      clearInterval(countdownInterval);
      countdownInterval = null;
      btn.disabled = false;
    }
  }, 1000);
}

function closeAdModal() {
  document.getElementById('adModal').classList.remove('active');
  if (countdownInterval) {
    clearInterval(countdownInterval);
    countdownInterval = null;
  }
}

function watchAd() {
  const btn = document.getElementById('watchAdBtn');
  if (btn.disabled) return;
  
  if (adMode === 'double') {
    adCount++;
    if (adCount === 1) {
      btn.textContent = '▶ Watch Ad 2/2 (30s)';
      btn.disabled = true;
      let t = 30;
      const countdown = document.getElementById('adCountdown');
      countdown.textContent = t;
      if (countdownInterval) clearInterval(countdownInterval);
      countdownInterval = setInterval(() => {
        t--;
        countdown.textContent = t;
        if (t <= 0) {
          clearInterval(countdownInterval);
          countdownInterval = null;
          btn.disabled = false;
        }
      }, 1000);
    } else {
      adWatchCount = 2;
      DAILY_LIMIT = 10;
      saveDailyCount();
      closeAdModal();
      alert('🎉 +5 questions added! You now have ' + (DAILY_LIMIT - dailyCount) + ' questions left.');
    }
  } else {
    adWatchCount = 1;
    DAILY_LIMIT = 10;
    saveDailyCount();
    closeAdModal();
    alert('🎉 +5 questions added! You now have ' + (DAILY_LIMIT - dailyCount) + ' questions left.');
  }
  updateUI();
}

function updateUI() {
  const uc = document.getElementById('usageCount');
  const fill = document.getElementById('usageFill');
  const msg = document.getElementById('upgradeMsg');
  const cd = document.getElementById('cooldownDisplay');
  
  if (!uc) return;
  
  if (isPremiumUser) {
    uc.innerHTML = '♾️ Unlimited';
    fill.style.width = '100%';
    msg.innerHTML = '👑 Premium active — unlimited & ad-free';
    if (cd) cd.style.display = 'none';
    return;
  }
  
  if (cooldownEndTime && cooldownEndTime > new Date()) {
    const remaining = Math.ceil((cooldownEndTime - new Date()) / (1000 * 60 * 60));
    cd.style.display = 'block';
    cd.innerHTML = `⏳ Cooldown: ${remaining}h remaining · Ask again after 12h`;
    uc.innerHTML = '⏳ On cooldown';
    fill.style.width = '100%';
    fill.style.background = 'var(--red)';
    msg.innerHTML = `⏳ ${remaining} hours remaining. Come back later!`;
    return;
  } else {
    if (cd) cd.style.display = 'none';
    fill.style.background = 'var(--grad-main)';
  }
  
  const remaining = DAILY_LIMIT - dailyCount;
  uc.innerHTML = dailyCount + ' / ' + DAILY_LIMIT;
  fill.style.width = Math.min((dailyCount/DAILY_LIMIT)*100,100) + '%';
  
  if (dailyCount >= DAILY_LIMIT) {
    if (adWatchCount === 0) {
      msg.innerHTML = '⚠️ Daily cap hit. <button class="watch-ad-btn" onclick="showAdModal(\'single\')">📺 Watch ad → +5</button> or <a href="#" onclick="showPremium();return false">Go Pro →</a>';
    } else if (adWatchCount === 1) {
      msg.innerHTML = '⚠️ Daily cap hit again. <button class="watch-ad-btn" onclick="showAdModal(\'double\')">📺 Watch 2 ads → +5</button> or <a href="#" onclick="showPremium();return false">Go Pro →</a>';
    } else {
      msg.innerHTML = '⏳ All ads used today. <a href="#" onclick="showPremium();return false">Go Pro →</a>';
      cd.style.display = 'block';
      cd.innerHTML = '⏳ Cooldown: 12h · Ask again after 12 hours';
    }
  } else {
    msg.innerHTML = '✨ <b>' + remaining + '</b> questions left today · <a href="#" onclick="showPremium();return false">Go Pro →</a>';
  }
}

