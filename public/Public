// ============================================================
document.getElementById('pdfFile').addEventListener('change', async (e)=>{
  const file = e.target.files[0]; if (!file) return;
  if (file.type !== 'application/pdf') { alert('Please pick a PDF file.'); return; }
  if (file.size > 15*1024*1024) { alert('PDF too large (max 15 MB).'); return; }
  const b64 = await fileToBase64(file);
  pendingPDF = { name: file.name, mime:'application/pdf', data: b64 };
  renderAttachBar();
  const ci=document.getElementById('ci');
  if (!ci.value.trim()) { ci.value = lang==='hi' ? 'Is PDF ko summarize karo aur key exam points nikalo.' : 'Summarize this PDF and pull out the key exam points.'; updBtn(); }
  e.target.value='';
});

function fileToBase64(file){ return new Promise((res,rej)=>{ const r=new FileReader(); r.onload=()=>res(String(r.result).split(',')[1]); r.onerror=rej; r.readAsDataURL(file); }); }

function renderAttachBar(){
  const bar = document.getElementById('attachBar'); if (!bar) return;
  bar.innerHTML = pendingPDF ? `<span class="attach-pill">📄 ${xe(pendingPDF.name)} <span class="x" onclick="clearPDF()">×</span></span>` : '';
}

function clearPDF(){ pendingPDF=null; renderAttachBar(); }

