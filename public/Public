<script>
// ============================================================
// HealthPulse Pro · Veda AI — COMPLETE VERSION
// 🔐 API key is on BACKEND (not in frontend!)
// 💳 UPI Payment Integrated
// 👑 Premium Auto-Expiry (30/365 days)
// ============================================================

// ============================================================
// 🔐 BACKEND URL — Auto detect domain (Render pe kaam karega!)
// ============================================================
const BACKEND_URL = window.location.origin;

console.log('🔗 Backend URL:', BACKEND_URL);

// ============================================================
// 💳 PAYMENT SYSTEM
// ============================================================
let selectedUPI = 'gpay';
let paymentAmount = 200;
let paymentPlan = 'monthly';

function selectUPI(method) {
  selectedUPI = method;
  document.querySelectorAll('.payment-option').forEach(el => el.classList.remove('selected'));
  document.querySelectorAll('.payment-option').forEach(el => {
    if (el.textContent.includes(method) || 
        (method === 'gpay' && el.textContent.includes('Google')) ||
        (method === 'phonepe' && el.textContent.includes('PhonePe')) ||
        (method === 'paytm' && el.textContent.includes('Paytm')) ||
        (method === 'other' && el.textContent.includes('Other'))) {
      el.classList.add('selected');
    }
  });
}

function initiatePayment(amount, plan) {
  const email = localStorage.getItem('userEmail');
  if (!email) {
    alert('Please login first!');
    return;
  }
  
  paymentAmount = amount;
  paymentPlan = plan || 'monthly';
  
  document.getElementById('paymentAmount').textContent = `₹${amount} / ${plan || 'monthly'}`;
  show('pg-payment');
}

async function processPayment() {
  const email = localStorage.getItem('userEmail');
  if (!email) {
    alert('Please login first!');
    return;
  }
  
  const btn = document.getElementById('payNowBtn');
  btn.textContent = '⏳ Processing...';
  btn.disabled = true;
  
  try {
    const response = await fetch(`${BACKEND_URL}/api/create-payment`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        amount: paymentAmount,
        email: email,
        plan: paymentPlan,
        phone: '9999999999'
      })
    });
    
    const data = await response.json();
    
    if (data.success) {
      alert('✅ Payment initiated! Redirecting to UPI...');
      window.location.href = data.paymentUrl;
    } else {
      alert('❌ Payment failed: ' + data.error);
      btn.textContent = '💳 Pay Now';
      btn.disabled = false;
    }
  } catch (error) {
    alert('❌ Error: ' + error.message);
    btn.textContent = '💳 Pay Now';
    btn.disabled = false;
  }
}

// Check payment success on page load
(function checkPaymentStatus() {
  const urlParams = new URLSearchParams(window.location.search);
  const paymentStatus = urlParams.get('payment');
  const email = urlParams.get('email');
  
  if (paymentStatus === 'success') {
    alert('🎉 Payment Successful! You are now a Premium member!');
    if (email) {
      localStorage.setItem('userEmail', email);
      fetchPremiumList();
    }
    window.history.replaceState({}, document.title, window.location.pathname);
  } else if (paymentStatus === 'failed') {
    alert('❌ Payment failed. Please try again.');
    window.history.replaceState({}, document.title, window.location.pathname);
  }
})();

// ============================================================
// 🔐 SECURE: API Call via Backend Proxy
// ============================================================
async function callDeepSeek(systemText, history, opts) {
  opts = opts || {};
  
  const messages = [];
  for (const m of history) {
    if (m.role === 'assistant') {
      messages.push({ role: "assistant", content: m.content });
    } else {
      let content = m.content || '';
      if (m.pdf) {
        content = (content ? content + ' ' : '') + '[PDF attached: ' + (m.pdf.name || 'document') + ']';
      }
      messages.push({ role: "user", content: content });
    }
  }
  
  const response = await fetch(`${BACKEND_URL}/api/chat`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      messages: messages,
      systemPrompt: systemText,
      temperature: opts.temperature || 0.3,
      maxTokens: opts.maxOutputTokens || 1400
    })
  });
  
  const data = await response.json();
  if (!data.success) {
    throw new Error(data.error || 'API error');
  }
  return data.reply;
}

// ============================================================
// 🔐 SECURE: MCQ Generation via Backend Proxy
// ============================================================
async function generateMCQ(prompt) {
  const response = await fetch(`${BACKEND_URL}/api/mcq`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ prompt })
  });
  const data = await response.json();
  if (!data.success) {
    throw new Error(data.error || 'MCQ generation failed');
  }
  return data.reply;
}

